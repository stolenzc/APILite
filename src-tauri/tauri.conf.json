{
  "productName": "APILite",
  "version": "0.1.0",
  "identifier": "com.APILite.app",
  "build": {
    "beforeBuildCommand": "npm run build -w frontend",
    "beforeDevCommand": "npm run dev -w frontend",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "APILite",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
